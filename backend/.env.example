# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000

# Frontend URL (for CORS - REQUIRED for production)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Upstash Redis Configuration
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Supabase Configuration
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Admin Configuration (comma-separated list of admin emails)
# These emails can access admin endpoints like vote reset and toggle
ADMIN_EMAILS=admin@example.com,admin2@example.com

# ============================================================
# NOTES
# ============================================================
# 
# 1. FRONTEND_URL must be set correctly for CORS to work
#    - Do NOT include trailing slash
#    - Must match exactly the origin of your frontend
#
# 2. ADMIN_EMAILS must include all admin users
#    - Case-insensitive
#    - Separated by commas
#
# 3. SUPABASE_SERVICE_ROLE_KEY bypasses RLS
#    - Keep this secret!
#    - Never expose in frontend code
#
# 4. For production deployment on Render:
#    - Set all these as environment variables in Render dashboard
#    - Do NOT commit .env file to git
#
